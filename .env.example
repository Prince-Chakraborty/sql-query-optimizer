# ─────────────────────────────────────────
# MANDATORY - Set these before running
# ─────────────────────────────────────────

# Your HuggingFace API token
HF_TOKEN=your_huggingface_token_here

# LLM API endpoint
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for inference
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Your deployed HF Space URL
HF_SPACE_URL=https://your-username-sql-query-optimizer.hf.space

# Local Docker image name (if using from_docker_image)
LOCAL_IMAGE_NAME=sql-query-optimizer

# Task to run (task_easy, task_medium, task_hard)
TASK_NAME=task_easy
